# ============================================================================
# Aegis Context Broker - Environment Configurations
# ============================================================================
# 
# 1. Copy this file to `.env` in the `backend/` directory.
# 2. DO NOT commit `.env` to version control.
# 3. Ensure your Google Cloud SDK is authenticated locally, or provide 
#    a service account path if not running on Cloud Run.
# ============================================================================

# The Google Cloud Project ID hosting Vertex AI, Firestore, and Secret Manager.
GOOGLE_CLOUD_PROJECT=aegis-488920

# The region to deploy and hit Vertex AI models.
GOOGLE_CLOUD_LOCATION=us-central1

# Application HTTP Port (Default is 8080 for Cloud Run compatibility)
PORT=8080

# (Optional) Local path to a GCP Service Account JSON key for local development.
# If omitted, @google-cloud libraries default to your CLI `gcloud auth application-default login` profile.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# (Optional) Firebase Admin SDK properties. Usually auto-detected in GCP environments.
# FIREBASE_PROJECT_ID=aegis-796f9

# Example 3rd Party App IDs (for future OAuth flows to intercept)
# GITHUB_CLIENT_ID=your-github-oauth-app-id
# GITHUB_CLIENT_SECRET=your-github-oauth-app-secret
# JIRA_CLIENT_ID=your-jira-oauth-app-id
